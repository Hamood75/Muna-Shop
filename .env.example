# Instant app (public id — safe to commit in examples). Admin token must stay secret in `.env` only.
NEXT_PUBLIC_INSTANT_APP_ID=9074607a-d23c-47e5-89a9-898d7400f273
INSTANT_APP_ADMIN_TOKEN=

# Same app via CLI (use a fresh token from the dashboard if this one was leaked):
# npx create-instant-app muna-shop --app 9074607a-d23c-47e5-89a9-898d7400f273 --token <YOUR_ADMIN_TOKEN> --next --rules

# Comma-separated emails that become super_admin (team management, env promotion on login).
# New users without a match get staff until an admin/super_admin changes their role.
SUPER_ADMIN_EMAIL=

# Copy to `.env.local` or `.env` (gitignored) and add INSTANT_APP_ADMIN_TOKEN. Restart `npm run dev` after changes.
#
# Vercel / CI: add NEXT_PUBLIC_INSTANT_APP_ID (and INSTANT_APP_ADMIN_TOKEN for server actions)
# in Project Settings → Environment Variables for Production + Preview, or builds can succeed
# but `/api/instant` returns 503 until the real app id is configured.

# If server actions fail with "Attributes are missing in your schema",
# sync InstantDB with this repo:
#   npx instant-cli login
#   npm run instant:push
# If schema push succeeds but perms fails with "Transport error (…/perms/pull)":
#   `npm run instant:push-perms` retries automatically (see scripts/instant-push-perms-with-retry.sh).
#   One shot: npm run instant:push-perms:once
#   Tune: INSTANT_PUSH_PERMS_ATTEMPTS=8 INSTANT_PUSH_PERMS_DELAY_SEC=20 npm run instant:push-perms
#
# Auth resolution order in instant-cli: -t flag → INSTANT_CLI_AUTH_TOKEN → INSTANT_APP_ADMIN_TOKEN → saved login file.
# If pushes behave oddly, try only ONE source: e.g. tabula rasa `unset INSTANT_APP_ADMIN_TOKEN` and use `npx instant-cli login`,
# or set INSTANT_CLI_AUTH_TOKEN from `npx instant-cli login --print` after logging in.

# After changing `instant.perms.ts`, also run: npm run instant:push-perms

# If you see only "fetch failed", the Next.js server cannot reach api.instantdb.com
# (wrong env, VPN/firewall, or offline). Same checklist as above.
